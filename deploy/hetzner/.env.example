# TinyZKP production environment variables.
# Copy to /opt/hc-stark/.env and fill in real values.

# API keys: "tenant_id:api_key" pairs, comma-separated.
HC_SERVER_API_KEYS=tenant1:CHANGE_ME

# Stripe billing.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx

# Paths (inside container or host).
HC_USAGE_DB_PATH=/opt/hc-stark/data/usage.sqlite
HC_TENANT_STORE_PATH=/opt/hc-stark/data/tenant_store.sqlite
HC_API_KEYS_FILE=/opt/hc-stark/data/api_keys.txt

# Monitoring.
GRAFANA_ADMIN_PASSWORD=changeme

# Prometheus AlertManager email recipient.
ALERT_EMAIL=logan@galenhealth.org

# Email delivery (optional — falls back to Stripe metadata if not set).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=xxx
SMTP_FROM=noreply@tinyzkp.com

# Alerting (optional — Slack/Discord webhook for billing alerts).
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Stripe Meter Event name (must match the Meter configured in Stripe dashboard).
STRIPE_METER_EVENT_NAME=proof_usage

# Internal secret shared between Cloudflare Pages Functions and billing-webhook.
# Must match the INTERNAL_SECRET set in Cloudflare Pages secrets.
INTERNAL_SECRET=CHANGE_ME_TO_A_RANDOM_STRING
